<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:c="using:SyncMaid.Controls">

    <!-- Surfaces. Default text colour lives on Window/UserControl so it INHERITS — letting
         buttons (white) and selected segments (teal) override their content text. -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{StaticResource PageBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Inter, sans-serif" />
    </Style>
    <Style Selector="UserControl">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Inter, sans-serif" />
    </Style>

    <!-- Typography (no Foreground here — it would defeat inheritance on buttons/segments) -->
    <Style Selector="TextBlock">
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="TextBlock.name">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="TextBlock.label">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,0,0,5" />
    </Style>
    <Style Selector="TextBlock.path">
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- Primary (teal) button -->
    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{StaticResource TealBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="13,7" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions><BrushTransition Property="Background" Duration="0:0:0.15" /></Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.primary /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource TealBrush}" />
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource TealHoverBrush}" />
        <Setter Property="TextBlock.Foreground" Value="White" />
    </Style>
    <Style Selector="Button.primary:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource TealPressedBrush}" />
    </Style>

    <!-- Secondary (ghost) button -->
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource HairlineStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.secondary /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource SubtleBrush}" />
    </Style>

    <!-- Danger button -->
    <Style Selector="Button.danger">
        <Setter Property="Background" Value="{StaticResource DangerBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="13,7" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.danger /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource DangerBrush}" />
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource DangerHoverBrush}" />
        <Setter Property="TextBlock.Foreground" Value="White" />
    </Style>

    <!-- Square icon button -->
    <Style Selector="Button.icon">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.icon /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource SubtleBrush}" />
    </Style>
    <Style Selector="Button.icon.run">
        <Setter Property="Foreground" Value="{StaticResource TealBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource TealBrush}" />
    </Style>
    <Style Selector="Button.icon.run:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource TealSubtleBrush}" />
    </Style>
    <Style Selector="Button.icon.danger">
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
    </Style>
    <Style Selector="Button.icon.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#F9E7E8" />
    </Style>
    <Style Selector="Button.icon:disabled">
        <Setter Property="Opacity" Value="0.4" />
    </Style>

    <!-- Title-bar caption buttons (custom chrome) -->
    <Style Selector="Button.caption">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.caption /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.caption:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource SubtleBrush}" />
    </Style>
    <Style Selector="Button.caption.close:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource DangerBrush}" />
        <Setter Property="TextBlock.Foreground" Value="White" />
    </Style>
    <Style Selector="Button.caption.close:pointerover">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Chevron toggle (card collapse) — custom template so Fluent's checked chrome
         never paints a filled box over the arrow. -->
    <Style Selector="ToggleButton.chevron">
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="Transparent" Padding="2">
                    <ContentPresenter Content="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Card -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <!-- Badges / pills -->
    <Style Selector="Border.badge">
        <Setter Property="Background" Value="{StaticResource SubtleBrush}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.badge TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="Border.badge.live">
        <Setter Property="Background" Value="{StaticResource TealSubtleBrush}" />
    </Style>
    <Style Selector="Border.badge.live TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TealBrush}" />
    </Style>
    <Style Selector="Border.badge.warn">
        <Setter Property="Background" Value="#FBEFD6" />
    </Style>
    <Style Selector="Border.badge.warn TextBlock">
        <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
    </Style>

    <!-- Teal chip (folder glyph holder) -->
    <Style Selector="Border.chip">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{StaticResource TealSubtleBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Inputs: grey hairline border (matching buttons), teal on focus -->
    <Style Selector="TextBox">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="9,6" />
        <Setter Property="BorderBrush" Value="{StaticResource HairlineStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBox /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{StaticResource HairlineStrongBrush}" />
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{StaticResource HairlineStrongBrush}" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{StaticResource TealBrush}" />
    </Style>
    <Style Selector="ComboBox">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="BorderBrush" Value="{StaticResource HairlineStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ComboBox /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{StaticResource HairlineStrongBrush}" />
    </Style>
    <!-- Numeric input (mass-delete threshold). Fluent's default chrome is the near-black
         TextControlBorderBrush; the brush set here flows through the template to the inner
         ButtonSpinner, its spin-button separators, and the text field, matching TextBox. -->
    <Style Selector="NumericUpDown">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="BorderBrush" Value="{StaticResource HairlineStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="NumericUpDown ButtonSpinner:pointerover">
        <Setter Property="BorderBrush" Value="{StaticResource HairlineStrongBrush}" />
    </Style>
    <Style Selector="NumericUpDown ButtonSpinner:focus-within">
        <Setter Property="BorderBrush" Value="{StaticResource TealBrush}" />
    </Style>

    <!-- Segmented selector (trigger type) -->
    <Style Selector="RadioButton.segment">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="root" CornerRadius="6" BorderThickness="1" Padding="{TemplateBinding Padding}"
                        BorderBrush="{StaticResource HairlineStrongBrush}" Background="Transparent">
                    <ContentPresenter Content="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <!-- Compact variant for in-card connective pickers (the filter groups' any/all). -->
    <Style Selector="RadioButton.segment.small">
        <Setter Property="Padding" Value="10,3" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="RadioButton.segment:pointerover /template/ Border#root">
        <Setter Property="Background" Value="{StaticResource SubtleBrush}" />
    </Style>
    <Style Selector="RadioButton.segment:checked /template/ Border#root">
        <Setter Property="BorderBrush" Value="{StaticResource TealBrush}" />
        <Setter Property="Background" Value="{StaticResource TealSubtleBrush}" />
    </Style>
    <Style Selector="RadioButton.segment:checked">
        <Setter Property="Foreground" Value="{StaticResource TealBrush}" />
    </Style>

    <!-- Choice card (sync strategy / file mode) -->
    <Style Selector="RadioButton.card">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="root" CornerRadius="8" BorderThickness="1" Padding="12,10"
                        BorderBrush="{StaticResource HairlineBrush}" Background="{StaticResource SurfaceBrush}">
                    <ContentPresenter Content="{TemplateBinding Content}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="RadioButton.card:pointerover /template/ Border#root">
        <Setter Property="BorderBrush" Value="{StaticResource HairlineStrongBrush}" />
    </Style>
    <Style Selector="RadioButton.card:checked /template/ Border#root">
        <Setter Property="BorderBrush" Value="{StaticResource TealBrush}" />
        <Setter Property="Background" Value="{StaticResource TealSubtleBrush}" />
    </Style>
    <!-- The custom template bypasses Fluent's disabled chrome, so an unavailable choice
         (e.g. Move when the task already has destinations) must dim itself. -->
    <Style Selector="RadioButton.card:disabled">
        <Setter Property="Cursor" Value="Arrow" />
    </Style>
    <Style Selector="RadioButton.card:disabled /template/ Border#root">
        <Setter Property="Opacity" Value="0.45" />
        <Setter Property="Background" Value="{StaticResource SubtleBrush}" />
    </Style>

    <!-- In-window modal -->
    <Style Selector="Border.backdrop">
        <Setter Property="Background" Value="#66000000" />
    </Style>
    <Style Selector="Border.dialogCard">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="BoxShadow" Value="0 18 50 0 #40000000" />
    </Style>
    <Style Selector="Border.filterRow">
        <Setter Property="Background" Value="{StaticResource SubtleBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,6" />
    </Style>

    <!-- Notice row (hints / warnings / previews): icon + wrapping text on the filterRow
         chrome. Every notice goes through this control — the Auto,* grid is what bounds the
         text's width so TextWrapping engages; an icon + text in a horizontal StackPanel
         measures the text unbounded and long messages overflow the box (issue #14).
         Foreground colours the icon: muted by default, or the "warning"/"danger" class. -->
    <Style Selector="c|HintBox">
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{StaticResource SubtleBrush}" CornerRadius="6" Padding="10,6">
                    <Grid ColumnDefinitions="Auto,*">
                        <mi:MaterialIcon Grid.Column="0" Kind="{TemplateBinding Icon}"
                                         Width="16" Height="16" Foreground="{TemplateBinding Foreground}"
                                         VerticalAlignment="Top" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" Classes="muted" TextWrapping="Wrap"
                                   VerticalAlignment="Center" Text="{TemplateBinding Text}" />
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="c|HintBox.warning">
        <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
    </Style>
    <Style Selector="c|HintBox.danger">
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
    </Style>

    <!-- Filter group card (destination editor): a bordered container for a set of rule rows. -->
    <Style Selector="Border.filterGroup">
        <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10" />
    </Style>

    <!-- Exclude toggle on a filter rule row: quiet until checked, then warning-tinted.
         Custom template so Fluent's checked chrome never paints its own filled box. -->
    <Style Selector="ToggleButton.exclude">
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="root" Background="Transparent" CornerRadius="6"
                        BorderThickness="1" BorderBrush="Transparent">
                    <ContentPresenter Content="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="ToggleButton.exclude:pointerover /template/ Border#root">
        <Setter Property="Background" Value="{StaticResource SubtleBrush}" />
    </Style>
    <Style Selector="ToggleButton.exclude:checked /template/ Border#root">
        <Setter Property="Background" Value="#FBEFD6" />
        <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
    </Style>
    <Style Selector="ToggleButton.exclude:checked">
        <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
    </Style>

    <!-- Sidebar list -->
    <Style Selector="ListBox.sidebar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBox.sidebar ListBoxItem">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Margin" Value="0,1" />
    </Style>
    <Style Selector="ListBox.sidebar ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{StaticResource TealSubtleBrush}" />
    </Style>
</Styles>
