<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SyncMaid.ViewModels"
             xmlns:conv="using:SyncMaid.Converters"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:model="using:SyncMaid.Core.Model"
             mc:Ignorable="d" d:DesignWidth="510"
             x:Class="SyncMaid.Views.DestinationEditorView"
             x:DataType="vm:DestinationEditorViewModel"
             x:CompileBindings="True">

    <Border Classes="dialogCard" Width="510" MaxHeight="640">
        <DockPanel Margin="24">
            <TextBlock DockPanel.Dock="Top" Text="Destination" FontSize="16" FontWeight="Medium" Margin="0,0,0,16" />

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,16,0,0">
                <Button Classes="secondary" Content="Cancel" Command="{Binding CancelCommand}" />
                <Button Classes="primary" Content="Save destination" Command="{Binding OKCommand}" />
            </StackPanel>

            <ScrollViewer>
                <StackPanel Spacing="16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Name" Classes="label" />
                        <TextBox Text="{Binding Name}" />
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Destination folder" Classes="label" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Text="{Binding Path}" Classes="path" />
                            <Button Grid.Column="1" Classes="secondary" Command="{Binding BrowseCommand}" Margin="8,0,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <mi:MaterialIcon Kind="FolderOutline" Width="15" Height="15" />
                                    <TextBlock Text="Browse" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Sync strategy" Classes="label" />
                        <StackPanel Spacing="8">
                            <RadioButton Classes="card" GroupName="strategy"
                                         IsChecked="{Binding SelectedStrategy, Converter={x:Static conv:EnumMatchConverter.Instance}, ConverterParameter={x:Static model:SyncStrategy.Mirror}}">
                                <Grid ColumnDefinitions="Auto,*">
                                    <mi:MaterialIcon Grid.Column="0" Kind="Sync" Width="20" Height="20" Foreground="{StaticResource TealBrush}" VerticalAlignment="Center" Margin="0,0,11,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Mirror" FontWeight="Medium" />
                                        <TextBlock Text="Keep the destination identical — copies new and changed files, deletes extras." Classes="muted" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </RadioButton>
                            <RadioButton Classes="card" GroupName="strategy"
                                         IsChecked="{Binding SelectedStrategy, Converter={x:Static conv:EnumMatchConverter.Instance}, ConverterParameter={x:Static model:SyncStrategy.AddOnly}}">
                                <Grid ColumnDefinitions="Auto,*">
                                    <mi:MaterialIcon Grid.Column="0" Kind="Plus" Width="20" Height="20" Foreground="{StaticResource TealBrush}" VerticalAlignment="Center" Margin="0,0,11,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Add-only" FontWeight="Medium" />
                                        <TextBlock Text="Copy new and changed files; never delete from the destination." Classes="muted" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </RadioButton>
                            <RadioButton Classes="card" GroupName="strategy"
                                         IsChecked="{Binding SelectedStrategy, Converter={x:Static conv:EnumMatchConverter.Instance}, ConverterParameter={x:Static model:SyncStrategy.Move}}">
                                <Grid ColumnDefinitions="Auto,*">
                                    <mi:MaterialIcon Grid.Column="0" Kind="ArrowRight" Width="20" Height="20" Foreground="{StaticResource TealBrush}" VerticalAlignment="Center" Margin="0,0,11,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Move" FontWeight="Medium" />
                                        <TextBlock Text="Move matching files to the destination, removing them from the source." Classes="muted" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </RadioButton>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Files to sync" Classes="label" />
                        <Grid ColumnDefinitions="*,8,*">
                            <RadioButton Grid.Column="0" Classes="segment" GroupName="files" IsChecked="{Binding SyncAll}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <mi:MaterialIcon Kind="Asterisk" Width="15" Height="15" />
                                    <TextBlock Text="All files" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Grid.Column="2" Classes="segment" GroupName="files" IsChecked="{Binding !SyncAll}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <mi:MaterialIcon Kind="FilterOutline" Width="15" Height="15" />
                                    <TextBlock Text="Only matching" />
                                </StackPanel>
                            </RadioButton>
                        </Grid>

                        <StackPanel IsVisible="{Binding !SyncAll}" Spacing="8" Margin="0,10,0,0">
                            <!-- Top-level connective: how the groups combine (only shown once
                                 there is more than one group). -->
                            <Grid ColumnDefinitions="*,8,*" IsVisible="{Binding HasMultipleGroups}">
                                <RadioButton Grid.Column="0" Classes="segment" GroupName="groupsConnective" IsChecked="{Binding !MatchAllGroups}"
                                             ToolTip.Tip="Sync files that match at least one group">
                                    <TextBlock Text="Match any group" />
                                </RadioButton>
                                <RadioButton Grid.Column="2" Classes="segment" GroupName="groupsConnective" IsChecked="{Binding MatchAllGroups}"
                                             ToolTip.Tip="Sync only files that match every group">
                                    <TextBlock Text="Match all groups" />
                                </RadioButton>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Groups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:FilterGroupViewModel">
                                        <Border Classes="filterGroup" Margin="0,0,0,8">
                                            <StackPanel Spacing="8">
                                                <!-- Group header: its own ANY/ALL connective; removable
                                                     when there are multiple groups. No GroupName on the
                                                     radios — they group by parent, per card. -->
                                                <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                                    <TextBlock Grid.Column="0" Text="Match" Classes="muted" VerticalAlignment="Center" Margin="2,0,8,0" />
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                                        <RadioButton Classes="segment small" IsChecked="{Binding !MatchAll}"
                                                                     ToolTip.Tip="A file matches this group when any rule matches (OR)">
                                                            <TextBlock Text="any rule" />
                                                        </RadioButton>
                                                        <RadioButton Classes="segment small" IsChecked="{Binding MatchAll}"
                                                                     ToolTip.Tip="A file matches this group only when every rule matches (AND)">
                                                            <TextBlock Text="all rules" />
                                                        </RadioButton>
                                                    </StackPanel>
                                                    <Button Grid.Column="3" Classes="icon" Width="26" Height="26" ToolTip.Tip="Remove group"
                                                            IsVisible="{Binding $parent[ItemsControl].((vm:DestinationEditorViewModel)DataContext).HasMultipleGroups, FallbackValue=False}"
                                                            Command="{Binding $parent[ItemsControl].((vm:DestinationEditorViewModel)DataContext).RemoveGroupCommand, FallbackValue={x:Null}}"
                                                            CommandParameter="{Binding}">
                                                        <mi:MaterialIcon Kind="Close" Width="13" Height="13" />
                                                    </Button>
                                                </Grid>

                                                <ItemsControl ItemsSource="{Binding Rules}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:FilterRuleViewModel">
                                                            <Border Classes="filterRow" Margin="0,0,0,6">
                                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                                                    <mi:MaterialIcon Grid.Column="0" Kind="FilterOutline" Width="15" Height="15" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextSecondaryBrush}" />
                                                                    <TextBlock Grid.Column="1" Text="{Binding Description}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Description}" />
                                                                    <ToggleButton Grid.Column="2" Classes="exclude" IsChecked="{Binding IsExcluded}" Margin="0,0,4,0"
                                                                                  ToolTip.Tip="Exclude — sync everything except files matching this rule">
                                                                        <mi:MaterialIcon Kind="Cancel" Width="13" Height="13" />
                                                                    </ToggleButton>
                                                                    <Button Grid.Column="3" Classes="icon" Width="26" Height="26"
                                                                            Command="{Binding $parent[ItemsControl].((vm:FilterGroupViewModel)DataContext).RemoveRuleCommand, FallbackValue={x:Null}}"
                                                                            CommandParameter="{Binding}" ToolTip.Tip="Remove">
                                                                        <mi:MaterialIcon Kind="Close" Width="13" Height="13" />
                                                                    </Button>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Grid ColumnDefinitions="Auto,*,Auto">
                                                    <ComboBox Grid.Column="0" ItemsSource="{Binding FilterKinds}" SelectedItem="{Binding SelectedFilterKind}" Width="120" />
                                                    <TextBox Grid.Column="1" Text="{Binding NewFilterPattern}" Margin="8,0" Classes="path" PlaceholderText="e.g. photos/2024 or jpg" />
                                                    <Button Grid.Column="2" Classes="primary" Command="{Binding AddRuleCommand}">
                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <mi:MaterialIcon Kind="Plus" Width="14" Height="14" />
                                                            <TextBlock Text="Add" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Classes="secondary" Command="{Binding AddGroupCommand}" HorizontalAlignment="Left"
                                    ToolTip.Tip="Combine groups to express e.g. (docs or photos) and jpg">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <mi:MaterialIcon Kind="Plus" Width="14" Height="14" />
                                    <TextBlock Text="Add group" />
                                </StackPanel>
                            </Button>

                            <!-- Live plain-text preview of the whole expression. -->
                            <Border Classes="filterRow">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <mi:MaterialIcon Kind="EyeOutline" Width="14" Height="14" VerticalAlignment="Center"
                                                     Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding FilterPreview}" Classes="muted" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Verification" Classes="label" />
                        <CheckBox IsChecked="{Binding VerifyContents}"
                                  Content="Verify file contents (xxHash) after each copy" />
                        <Border IsVisible="{Binding ShowVerifyNetworkWarning}" Classes="filterRow" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="AlertOutline" Width="16" Height="16"
                                                 Foreground="{StaticResource DangerBrush}" VerticalAlignment="Top" />
                                <TextBlock Classes="muted" TextWrapping="Wrap"
                                           Text="This is a network location. Content verification re-reads every copied file over the network (slower, more bandwidth). It guards against silent/hardware corruption the network protocol does not." />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding SelectedStrategy, Converter={x:Static conv:EnumMatchConverter.Instance}, ConverterParameter={x:Static model:SyncStrategy.Mirror}}">
                        <TextBlock Text="When removing extra files" Classes="label" />
                        <Grid ColumnDefinitions="*,8,*">
                            <RadioButton Grid.Column="0" Classes="segment" GroupName="delete"
                                         IsChecked="{Binding SelectedDeleteMode, Converter={x:Static conv:EnumMatchConverter.Instance}, ConverterParameter={x:Static model:DeleteMode.Recycle}}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <mi:MaterialIcon Kind="RecycleVariant" Width="15" Height="15" />
                                    <TextBlock Text="Recycle Bin" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Grid.Column="2" Classes="segment" GroupName="delete"
                                         IsChecked="{Binding SelectedDeleteMode, Converter={x:Static conv:EnumMatchConverter.Instance}, ConverterParameter={x:Static model:DeleteMode.Permanent}}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <mi:MaterialIcon Kind="DeleteForeverOutline" Width="15" Height="15" />
                                    <TextBlock Text="Delete permanently" />
                                </StackPanel>
                            </RadioButton>
                        </Grid>

                        <CheckBox IsChecked="{Binding ConfirmLargeDeletions}"
                                  Content="Confirm before a large deletion" Margin="0,10,0,0" />
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="24,2,0,0"
                                    IsVisible="{Binding ConfirmLargeDeletions}">
                            <TextBlock Text="Ask when deleting more than" Classes="muted" VerticalAlignment="Center" />
                            <NumericUpDown Value="{Binding MassDeletePercent}" Minimum="1" Maximum="100"
                                           Increment="5" FormatString="0" Width="120" />
                            <TextBlock Text="% of the destination" Classes="muted" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
