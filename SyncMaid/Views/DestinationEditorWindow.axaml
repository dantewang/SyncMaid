<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SyncMaid.ViewModels"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        x:Class="SyncMaid.Views.DestinationEditorWindow"
        x:DataType="vm:DestinationEditorViewModel"
        x:CompileBindings="True"
        Title="Destination Editor"
        Width="500" Height="600"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Width" Value="120" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style Selector="StackPanel.field">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,4" />
        </Style>
        <Style Selector="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinWidth" Value="70" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="20,10,20,20">
            <Button Content="OK"
                    Command="{Binding OKCommand}"
                    IsDefault="True" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True" />
        </StackPanel>

        <ScrollViewer Margin="20,20,20,0">
            <StackPanel Spacing="10" Margin="0,0,15,0">
                <StackPanel Classes="field">
                    <TextBlock Text="Name:" Classes="label" />
                    <TextBox Text="{Binding Name}" Width="250" />
                </StackPanel>

                <StackPanel Classes="field">
                    <TextBlock Text="Destination Path:" Classes="label" />
                    <TextBox Text="{Binding Path}" Width="200" />
                    <Button Content="Browse..."
                            Command="{Binding BrowseCommand}"
                            Margin="4,0,0,0" />
                </StackPanel>

                <StackPanel Classes="field" Margin="0,10">
                    <TextBlock Text="Sync Strategy:" Classes="label" />
                    <ComboBox ItemsSource="{Binding SyncStrategies}"
                              SelectedItem="{Binding SelectedStrategy}"
                              Width="150" />
                </StackPanel>

                <StackPanel Classes="field" Margin="0,10">
                    <TextBlock Text="File Filter:" Classes="label" />
                    <StackPanel>
                        <RadioButton Content="Sync All Files"
                                    IsChecked="{Binding SyncAll}" />
                        <RadioButton Content="Use Filters"
                                    IsChecked="{Binding !SyncAll}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel IsVisible="{Binding !SyncAll}"
                          Margin="120,0,0,0">
                    <Border BorderBrush="Gray" 
                            BorderThickness="1" 
                            CornerRadius="4"
                            Padding="10">
                        <Grid RowDefinitions="Auto,*">
                            <WrapPanel Grid.Row="0"
                                      Orientation="Horizontal"
                                      Margin="0,0,0,10">
                                <TextBox Text="{Binding NewFilterPattern}"
                                         Width="200"
                                         Margin="0,0,10,4"
                                         PlaceholderText="e.g. photos/2024 or jpg" />
                                <ComboBox ItemsSource="{Binding FilterKinds}"
                                          SelectedItem="{Binding SelectedFilterKind}"
                                          Width="100"
                                          Margin="0,0,10,4" />
                                <Button Content="Add"
                                        Command="{Binding AddFilterCommand}"
                                        Margin="0,0,0,4" />
                            </WrapPanel>

                            <ListBox Grid.Row="1"
                                    ItemsSource="{Binding Filters}"
                                    MinHeight="150"
                                    MaxHeight="200">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:FilterRuleViewModel">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Command="{Binding $parent[ListBox].((vm:DestinationEditorViewModel)DataContext).RemoveFilterCommand, FallbackValue={x:Null}}"
                                                    CommandParameter="{Binding}"
                                                    Content="Remove" />
                                            <TextBlock Text="{Binding Description}"
                                                      VerticalAlignment="Center" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
