<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SyncMaid.ViewModels"
        xmlns:conv="using:SyncMaid.Converters"
        xmlns:model="using:SyncMaid.Core.Model"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="640"
        x:Class="SyncMaid.Views.DestinationEditorWindow"
        x:DataType="vm:DestinationEditorViewModel"
        x:CompileBindings="True"
        Title="Destination editor"
        Width="500" Height="640"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <SolidColorBrush x:Key="MutedBrush" Color="#7A7A76" />
        <SolidColorBrush x:Key="HairlineBrush" Color="#33000000" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="TextBlock.desc">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="20,12,20,18">
            <Button Content="Cancel" Command="{Binding CancelCommand}" IsCancel="True" Width="80" />
            <Button Content="Save destination" Command="{Binding OKCommand}" IsDefault="True" Width="140" />
        </StackPanel>

        <ScrollViewer Margin="20,20,20,0">
            <StackPanel Spacing="16" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Name" Classes="label" />
                    <TextBox Text="{Binding Name}" />
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Destination folder" Classes="label" />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0" Text="{Binding Path}" FontFamily="Consolas, monospace" />
                        <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseCommand}" Margin="8,0,0,0" />
                    </Grid>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Sync strategy" Classes="label" />
                    <StackPanel Spacing="6">
                        <RadioButton GroupName="strategy"
                                     IsChecked="{Binding SelectedStrategy, Converter={x:Static conv:EnumMatchConverter.Instance}, ConverterParameter={x:Static model:SyncStrategy.Mirror}}">
                            <StackPanel>
                                <TextBlock Text="Mirror" FontWeight="Medium" />
                                <TextBlock Text="Keep the destination identical — copies new and changed files, deletes extras." Classes="desc" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="strategy"
                                     IsChecked="{Binding SelectedStrategy, Converter={x:Static conv:EnumMatchConverter.Instance}, ConverterParameter={x:Static model:SyncStrategy.AddOnly}}">
                            <StackPanel>
                                <TextBlock Text="Add-only" FontWeight="Medium" />
                                <TextBlock Text="Copy new and changed files; never delete from the destination." Classes="desc" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="strategy"
                                     IsChecked="{Binding SelectedStrategy, Converter={x:Static conv:EnumMatchConverter.Instance}, ConverterParameter={x:Static model:SyncStrategy.Move}}">
                            <StackPanel>
                                <TextBlock Text="Move" FontWeight="Medium" />
                                <TextBlock Text="Move matching files to the destination, removing them from the source." Classes="desc" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Files to sync" Classes="label" />
                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <RadioButton GroupName="files" Content="All files" IsChecked="{Binding SyncAll}" />
                        <RadioButton GroupName="files" Content="Only matching filters" IsChecked="{Binding !SyncAll}" />
                    </StackPanel>

                    <Border IsVisible="{Binding !SyncAll}"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,8,0,0">
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <ComboBox Grid.Column="0" ItemsSource="{Binding FilterKinds}"
                                          SelectedItem="{Binding SelectedFilterKind}" Width="110" />
                                <TextBox Grid.Column="1" Text="{Binding NewFilterPattern}" Margin="8,0"
                                         FontFamily="Consolas, monospace" PlaceholderText="e.g. photos/2024 or jpg" />
                                <Button Grid.Column="2" Content="Add" Command="{Binding AddFilterCommand}" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Filters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:FilterRuleViewModel">
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                                            <TextBlock Grid.Column="0" Text="{Binding Description}" VerticalAlignment="Center" />
                                            <Button Grid.Column="1" Content="Remove"
                                                    Command="{Binding $parent[ItemsControl].((vm:DestinationEditorViewModel)DataContext).RemoveFilterCommand, FallbackValue={x:Null}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
