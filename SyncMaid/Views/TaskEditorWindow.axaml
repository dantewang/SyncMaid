<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SyncMaid.ViewModels"
        xmlns:conv="using:SyncMaid.Converters"
        mc:Ignorable="d" d:DesignWidth="460" d:DesignHeight="380"
        x:Class="SyncMaid.Views.TaskEditorWindow"
        x:DataType="vm:TaskEditorViewModel"
        x:CompileBindings="True"
        Title="Task editor"
        Width="460" Height="380"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <SolidColorBrush x:Key="MutedBrush" Color="#7A7A76" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="TextBlock.hint">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </Window.Styles>

    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="0,16,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}" IsCancel="True" Width="80" />
            <Button Content="Save task" Command="{Binding OKCommand}" IsDefault="True" Width="100" />
        </StackPanel>

        <StackPanel Spacing="14">
            <StackPanel>
                <TextBlock Text="Name" Classes="label" />
                <TextBox Text="{Binding Name}" />
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Source folder" Classes="label" />
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Text="{Binding Path}" FontFamily="Consolas, monospace" />
                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseCommand}" Margin="8,0,0,0" />
                </Grid>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Trigger" Classes="label" />
                <StackPanel Orientation="Horizontal" Spacing="18">
                    <RadioButton GroupName="trigger" Content="Manual"
                                 IsChecked="{Binding SelectedTriggerType, Converter={x:Static conv:EnumMatchConverter.Instance}, ConverterParameter={x:Static vm:TaskTriggerType.Manual}}" />
                    <RadioButton GroupName="trigger" Content="Scheduled"
                                 IsChecked="{Binding SelectedTriggerType, Converter={x:Static conv:EnumMatchConverter.Instance}, ConverterParameter={x:Static vm:TaskTriggerType.Scheduled}}" />
                    <RadioButton GroupName="trigger" Content="Watch"
                                 IsChecked="{Binding SelectedTriggerType, Converter={x:Static conv:EnumMatchConverter.Instance}, ConverterParameter={x:Static vm:TaskTriggerType.Watch}}" />
                </StackPanel>
            </StackPanel>

            <StackPanel IsVisible="{Binding IsScheduledTrigger}">
                <TextBlock Text="Cron expression" Classes="label" />
                <TextBox Text="{Binding CronExpression}" FontFamily="Consolas, monospace"
                         PlaceholderText="*/5 * * * *" />
                <TextBlock Text="{Binding CronPreview}" Classes="hint" />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
