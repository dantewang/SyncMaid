<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SyncMaid.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400"
             x:Class="SyncMaid.Views.ConfirmView"
             x:DataType="vm:ConfirmViewModel"
             x:CompileBindings="True">

    <Border Classes="dialogCard" Width="400">
        <StackPanel Margin="24" Spacing="14">
            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Medium" />
            <TextBlock Text="{Binding Message}" Classes="muted" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,4,0,0">
                <Button Classes="secondary" Content="Cancel" Command="{Binding CancelCommand}" />
                <Button Content="{Binding ConfirmLabel}" Command="{Binding ConfirmCommand}"
                        Classes.danger="{Binding IsDestructive}" Classes.primary="{Binding !IsDestructive}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
