<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SyncMaid.ViewModels"
             xmlns:c="using:SyncMaid.Controls"
             xmlns:l="using:SyncMaid.Markup"
             mc:Ignorable="d" d:DesignWidth="440"
             x:Class="SyncMaid.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="True">

    <!-- Same shell as the destination editor: title and Done stay docked while the options
         scroll, so a small main window never puts a setting (or the Done button) out of
         reach — the overlay caps the card at the window height and the ScrollViewer
         takes over from there. -->
    <Border Classes="dialogCard" Width="440" MaxHeight="640">
        <DockPanel Margin="24">
            <TextBlock DockPanel.Dock="Top" Text="{l:Loc Settings.Title}" FontSize="16" FontWeight="Medium" Margin="0,0,0,16" />

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,16,0,0">
                <Button Classes="primary" Content="{l:Loc Settings.Done}" Command="{Binding DoneCommand}" />
            </StackPanel>

            <ScrollViewer>
                <StackPanel Spacing="16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="{l:Loc Settings.LanguageLabel}" Classes="label" />
                        <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}"
                                  MinWidth="220">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:LanguageOption">
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="{l:Loc Settings.StartupLabel}" Classes="label" />
                        <CheckBox IsChecked="{Binding StartWithWindows}" IsEnabled="{Binding !IsDisabledByWindows}"
                                  Content="{l:Loc Settings.StartWithWindows}" />
                        <TextBlock Text="{l:Loc Settings.StartWithWindowsDesc}" Classes="muted" Margin="0,4,0,0" />

                        <c:HintBox Classes="danger" IsVisible="{Binding IsDisabledByWindows}"
                                   Text="{l:Loc Settings.StartupDisabledByWindows}" Margin="0,8,0,0" />
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="{l:Loc Settings.WindowLabel}" Classes="label" />
                        <CheckBox IsChecked="{Binding CloseToTray}"
                                  Content="{l:Loc Settings.CloseToTray}" />
                        <TextBlock Text="{l:Loc Settings.CloseToTrayDesc}"
                                   Classes="muted" TextWrapping="Wrap" Margin="0,4,0,0" />
                        <CheckBox IsChecked="{Binding StartMinimized}"
                                  Content="{l:Loc Settings.StartMinimized}" Margin="0,8,0,0" />
                        <TextBlock Text="{l:Loc Settings.StartMinimizedDesc}"
                                   Classes="muted" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="{l:Loc Settings.StorageLabel}" Classes="label" />
                        <TextBlock Text="{Binding StorageModeText}" />
                        <TextBlock Text="{Binding StoragePath}" Classes="muted" TextWrapping="Wrap" Margin="0,2,0,0" />
                        <Button Classes="secondary" Content="{Binding SwitchStorageText}"
                                Command="{Binding SwitchStorageCommand}" Margin="0,8,0,0" />
                        <TextBlock Text="{l:Loc Settings.SwitchStorageDesc}"
                                   Classes="muted" TextWrapping="Wrap" Margin="0,4,0,0" />

                        <c:HintBox Classes="danger" IsVisible="{Binding HasStorageError}"
                                   Text="{Binding StorageError}" Margin="0,8,0,0" />
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="{l:Loc Settings.AboutLabel}" Classes="label" />
                        <TextBlock Text="{Binding AppVersion}" Classes="muted" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
