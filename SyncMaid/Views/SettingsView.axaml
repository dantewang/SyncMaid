<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SyncMaid.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:l="using:SyncMaid.Markup"
             mc:Ignorable="d" d:DesignWidth="440"
             x:Class="SyncMaid.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="True">

    <Border Classes="dialogCard" Width="440">
        <StackPanel Margin="24" Spacing="16">
            <TextBlock Text="{l:Loc Settings.Title}" FontSize="16" FontWeight="Medium" />

            <StackPanel>
                <TextBlock Text="{l:Loc Settings.LanguageLabel}" Classes="label" />
                <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}"
                          MinWidth="220">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:LanguageOption">
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="{l:Loc Settings.StartupLabel}" Classes="label" />
                <CheckBox IsChecked="{Binding StartWithWindows}" IsEnabled="{Binding !IsDisabledByWindows}"
                          Content="{l:Loc Settings.StartWithWindows}" />
                <TextBlock Text="{l:Loc Settings.StartWithWindowsDesc}" Classes="muted" Margin="0,4,0,0" />

                <Border IsVisible="{Binding IsDisabledByWindows}" Classes="filterRow" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="AlertOutline" Width="16" Height="16"
                                         Foreground="{StaticResource DangerBrush}" VerticalAlignment="Top" />
                        <TextBlock Classes="muted" TextWrapping="Wrap"
                                   Text="{l:Loc Settings.StartupDisabledByWindows}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="{l:Loc Settings.WindowLabel}" Classes="label" />
                <CheckBox IsChecked="{Binding CloseToTray}"
                          Content="{l:Loc Settings.CloseToTray}" />
                <TextBlock Text="{l:Loc Settings.CloseToTrayDesc}"
                           Classes="muted" TextWrapping="Wrap" Margin="0,4,0,0" />
            </StackPanel>

            <StackPanel>
                <TextBlock Text="{l:Loc Settings.StorageLabel}" Classes="label" />
                <TextBlock Text="{Binding StorageModeText}" />
                <TextBlock Text="{Binding StoragePath}" Classes="muted" TextWrapping="Wrap" Margin="0,2,0,0" />
                <Button Classes="secondary" Content="{Binding SwitchStorageText}"
                        Command="{Binding SwitchStorageCommand}" Margin="0,8,0,0" />
                <TextBlock Text="{l:Loc Settings.SwitchStorageDesc}"
                           Classes="muted" TextWrapping="Wrap" Margin="0,4,0,0" />

                <Border IsVisible="{Binding HasStorageError}" Classes="filterRow" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="AlertOutline" Width="16" Height="16"
                                         Foreground="{StaticResource DangerBrush}" VerticalAlignment="Top" />
                        <TextBlock Classes="muted" TextWrapping="Wrap" Text="{Binding StorageError}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,4,0,0">
                <Button Classes="primary" Content="{l:Loc Settings.Done}" Command="{Binding DoneCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
