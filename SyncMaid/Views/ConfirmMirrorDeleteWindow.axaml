<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SyncMaid.ViewModels"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="480"
        x:Class="SyncMaid.Views.ConfirmMirrorDeleteWindow"
        x:DataType="vm:ConfirmMirrorDeleteViewModel"
        x:CompileBindings="True"
        Width="480" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/syncmaid.ico"
        Title="SyncMaid — confirm deletions">

    <StackPanel Margin="24" Spacing="14">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <mi:MaterialIcon Kind="AlertOutline" Width="22" Height="22"
                             Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center" />
            <TextBlock Text="Review deletions" FontSize="16" FontWeight="Medium" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Text="{Binding Explanation}" Classes="muted" TextWrapping="Wrap" />
        <TextBlock Text="{Binding DestinationPath}" Classes="path" TextTrimming="CharacterEllipsis" />

        <Border Classes="filterRow" MaxHeight="220">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Sample}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{Binding}" Classes="path" Margin="0,1" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
        <TextBlock Text="{Binding MoreText}" IsVisible="{Binding HasMore}" Classes="muted" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,4,0,0">
            <Button Classes="secondary" Content="Keep them" Command="{Binding KeepCommand}" />
            <Button Classes="danger" Content="{Binding ConfirmLabel}" Command="{Binding DeleteCommand}" />
        </StackPanel>
    </StackPanel>
</Window>
