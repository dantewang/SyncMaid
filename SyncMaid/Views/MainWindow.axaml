<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SyncMaid.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SyncMaid.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="True"
        Icon="/Assets/avalonia-logo.ico"
        Title="SyncMaid">

    <Window.Resources>
        <!-- Colors for regular action button -->
        <SolidColorBrush x:Key="ActionButtonBackground" Color="#39C5BB" />
        <SolidColorBrush x:Key="ActionButtonBackgroundHover" Color="#06B0A4" />
        <SolidColorBrush x:Key="ActionButtonBackgroundPressed" Color="#288C85" />
        <SolidColorBrush x:Key="ActionButtonBackgroundDisabled" Color="#90E1DB" />

        <!-- Colors for danger button -->
        <SolidColorBrush x:Key="DangerButtonBackground" Color="#C53943" />
        <SolidColorBrush x:Key="DangerButtonBackgroundHover" Color="#B00613" />
        <SolidColorBrush x:Key="DangerButtonBackgroundPressed" Color="#8C282F" />
        <SolidColorBrush x:Key="DangerButtonBackgroundDisabled" Color="#E19096" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.action">
            <Setter Property="Background" Value="{StaticResource ActionButtonBackground}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>

        <!-- Action Button States -->
        <Style Selector="Button.action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ActionButtonBackgroundHover}" />
            <Setter Property="TextBlock.Foreground" Value="White" />
        </Style>

        <Style Selector="Button.action:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ActionButtonBackgroundPressed}" />
        </Style>

        <Style Selector="Button.action:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ActionButtonBackgroundDisabled}" />
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{StaticResource DangerButtonBackground}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>

        <!-- Danger Button States -->
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerButtonBackgroundHover}" />
            <Setter Property="TextBlock.Foreground" Value="White" />
        </Style>

        <Style Selector="Button.danger:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerButtonBackgroundPressed}" />
        </Style>

        <Style Selector="Button.danger:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerButtonBackgroundDisabled}" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Toolbar -->
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Spacing="10" Margin="8,4">
            <Button Name="NewButton" 
                    Classes="action"
                    Command="{Binding AddTaskCommand}">
                <TextBlock Text="New Task" Margin="4,0,0,0" VerticalAlignment="Center" />
            </Button>
        </StackPanel>

        <!-- Main TreeView -->
        <TreeView Margin="8" ItemsSource="{Binding Nodes}">
            <TreeView.ItemTemplate>
                <!-- Task Node Template -->
                <TreeDataTemplate DataType="{x:Type vm:TaskNodeViewModel}" ItemsSource="{Binding Children}">
                    <DockPanel LastChildFill="True" HorizontalAlignment="Stretch">
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    Margin="8,0,0,0">
                            <Button Classes="action"
                                    Command="{Binding ExecuteCommand}"
                                    Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Execute"
                                               Margin="4,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Classes="action"
                                    Command="{Binding AddDestinationCommand}"
                                    Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Add Destination"
                                               Margin="4,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Classes="action"
                                    Command="{Binding EditCommand}"
                                    Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Edit"
                                               Margin="4,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Classes="danger"
                                    Command="{Binding DeleteCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Delete"
                                               Margin="4,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" />
                            <TextBlock Text="{Binding Path}"
                                       FontFamily="Consolas" />
                        </StackPanel>
                    </DockPanel>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>

            <TreeView.DataTemplates>
                <DataTemplate DataType="{x:Type vm:DestinationNodeViewModel}">
                    <DockPanel LastChildFill="True" HorizontalAlignment="Stretch">
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    Margin="8,0,0,0">
                            <Button Classes="action"
                                    Command="{Binding EditCommand}"
                                    Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Edit"
                                               Margin="4,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Classes="danger"
                                    Command="{Binding DeleteCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Delete"
                                               Margin="4,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" />
                            <TextBlock Text="{Binding Path}"
                                       FontFamily="Consolas" />
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </TreeView.DataTemplates>
        </TreeView>
    </DockPanel>
</Window>