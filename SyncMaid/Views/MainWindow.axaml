<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SyncMaid.ViewModels"
        xmlns:conv="using:SyncMaid.Converters"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:chrome="using:Avalonia.Controls.Chrome"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="620"
        x:Class="SyncMaid.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="True"
        Width="940" Height="620"
        Icon="/Assets/syncmaid.ico"
        TransparencyLevelHint="AcrylicBlur,Blur,None"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="40"
        WindowDecorations="BorderOnly"
        Title="SyncMaid">

    <Window.Styles>
        <Style Selector="mi|MaterialIcon#MaximizeIcon">
            <Setter Property="Kind" Value="WindowMaximize" />
        </Style>
        <Style Selector="Window[WindowState=Maximized] mi|MaterialIcon#MaximizeIcon">
            <Setter Property="Kind" Value="WindowRestore" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*">
        <!-- Frosted acrylic background spanning the extended title bar AND the body, so the
             glass is one continuous region across the custom title bar and the sidebar.
             Cards stay opaque so content readability is unaffected; falls back to a solid
             fill when Windows transparency is disabled. -->
        <ExperimentalAcrylicBorder Grid.Row="0" Grid.RowSpan="2" IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="#F7F7F4"
                                             TintOpacity="1" MaterialOpacity="0.6" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <!-- Custom title bar (40px). Transparent so the acrylic behind it shows through and
             reads as one glass region with the sidebar below. The ElementRole attached
             properties (only active because ExtendClientAreaToDecorationsHint is true) give
             Windows native non-client hit testing back: TitleBar => drag/double-click/system
             menu; the caption roles => native snap-layout flyout etc.
             WindowDecorations="BorderOnly" on the Window is what stops Avalonia's own
             WindowDrawnDecorations layer (built-in title text + caption buttons) from being
             drawn on top of this bar — the extend hint activates that layer when
             WindowDecorations is left at Full — while keeping the resize border and shadow.
             Known limitation (accepted): with BorderOnly the right-click / Alt+Space
             system menu on the title bar is unavailable. -->
        <Border Grid.Row="0" Name="TitleBar" Background="Transparent"
                chrome:WindowDecorationProperties.ElementRole="TitleBar">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <Image Source="/Assets/syncmaid.ico" Width="16" Height="16"
                           VerticalAlignment="Center" />
                    <TextBlock Text="SyncMaid" FontSize="13" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <!-- Column 1 is the star spacer: part of the draggable TitleBar strip. -->

                <Button Grid.Column="2" Classes="caption" Command="{Binding OpenSettingsCommand}"
                        ToolTip.Tip="Settings"
                        chrome:WindowDecorationProperties.ElementRole="User">
                    <mi:MaterialIcon Kind="CogOutline" Width="16" Height="16" />
                </Button>

                <Button Grid.Column="3" Name="MinimizeButton" Classes="caption"
                        Click="OnMinimize" ToolTip.Tip="Minimize"
                        chrome:WindowDecorationProperties.ElementRole="MinimizeButton">
                    <mi:MaterialIcon Kind="WindowMinimize" Width="16" Height="16" />
                </Button>
                <Button Grid.Column="4" Name="MaximizeButton" Classes="caption"
                        Click="OnMaximizeRestore" ToolTip.Tip="Maximize"
                        chrome:WindowDecorationProperties.ElementRole="MaximizeButton">
                    <mi:MaterialIcon Name="MaximizeIcon" Width="16" Height="16" />
                </Button>
                <Button Grid.Column="5" Name="CloseButton" Classes="caption close"
                        Click="OnClose" ToolTip.Tip="Close"
                        chrome:WindowDecorationProperties.ElementRole="CloseButton">
                    <mi:MaterialIcon Kind="Close" Width="16" Height="16" />
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*">
            <!-- Sidebar: compact task list. No right hairline: the glass butts directly
                 against the rounded solid pane, and the acrylic/PageBrush tonal contrast is
                 the separation (a divider line would cut across the rounded corner). -->
            <Border Grid.Column="0" Width="210" IsVisible="{Binding IsSidebarVisible}"
                    Background="Transparent">
                <DockPanel Margin="8">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="6,6,2,8">
                        <TextBlock Grid.Column="0" Text="Tasks" Classes="muted" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Classes="icon" Width="26" Height="26" Command="{Binding ToggleSidebarCommand}" ToolTip.Tip="Hide sidebar">
                            <mi:MaterialIcon Kind="ChevronLeft" Width="16" Height="16" />
                        </Button>
                    </Grid>
                    <ListBox Classes="sidebar" ItemsSource="{Binding Nodes}" SelectedItem="{Binding SelectedTask}"
                             SelectionChanged="OnTaskSelected">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TaskNodeViewModel">
                                <Grid ColumnDefinitions="Auto,*" ToolTip.Tip="{Binding SidebarTooltip}">
                                    <mi:MaterialIcon Grid.Column="0" Kind="FolderOutline" Width="18" Height="18"
                                                     Foreground="{StaticResource TealBrush}" VerticalAlignment="Center" Margin="0,0,9,0" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TealBrush}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Path}" Classes="path" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Rail when sidebar hidden (borderless, same as the sidebar) -->
            <Border Grid.Column="1" Width="40" IsVisible="{Binding !IsSidebarVisible}"
                    Background="Transparent">
                <Button Classes="icon" Width="26" Height="26" Command="{Binding ToggleSidebarCommand}"
                        HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0" ToolTip.Tip="Show sidebar">
                    <mi:MaterialIcon Kind="ChevronRight" Width="16" Height="16" />
                </Button>
            </Border>

            <!-- Main area: solid pane; the acrylic shows through the sidebar instead.
                 The rounded top-left corner (matching the card radius) softens the inner
                 corner of the glass L-shape formed by the title bar above and the sidebar
                 to the left — the acrylic shows through the rounded-off notch. The
                 glass-to-pane transition is borderless by design (Windows 11 Terminal /
                 Settings pattern). -->
            <Border Grid.Column="2" Background="{StaticResource PageBrush}" CornerRadius="12,0,0,0">
            <DockPanel Margin="16,12">
                <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="0,0,0,12">
                    <TextBlock Grid.Column="0" Text="Sync tasks" Classes="h1" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="secondary" Command="{Binding ToggleExpandAllCommand}" Content="{Binding ExpandCollapseLabel}" Margin="0,0,8,0" />
                    <Button Grid.Column="3" Classes="secondary" Command="{Binding RunAllCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="Play" Width="15" Height="15" />
                            <TextBlock Text="Run all" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4" Classes="primary" Command="{Binding AddTaskCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="Plus" Width="15" Height="15" />
                            <TextBlock Text="New task" />
                        </StackPanel>
                    </Button>
                </Grid>

                <ScrollViewer>
                    <ItemsControl x:Name="TasksItemsControl" ItemsSource="{Binding Nodes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TaskNodeViewModel">
                                <Border Classes="card">
                                    <StackPanel>
                                        <!-- Header -->
                                        <Grid ColumnDefinitions="*,Auto" Margin="10">
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <ToggleButton Classes="chevron" IsChecked="{Binding IsExpanded}" VerticalAlignment="Center" Margin="0,0,4,0">
                                                    <mi:MaterialIcon Width="18" Height="18"
                                                                     Kind="{Binding IsExpanded, Converter={x:Static conv:BoolToChevronKindConverter.Instance}}" />
                                                </ToggleButton>
                                                <Border Classes="chip" Margin="0,0,11,0">
                                                    <mi:MaterialIcon Kind="FolderOutline" Width="19" Height="19" Foreground="{StaticResource TealBrush}"
                                                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Name}" Classes="name" VerticalAlignment="Center" />
                                                        <Border Classes="badge">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <mi:MaterialIcon Kind="{Binding TriggerIconKind}" Width="12" Height="12"
                                                                                 Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                                                <TextBlock Text="{Binding TriggerText}" />
                                                            </StackPanel>
                                                        </Border>
                                                        <!-- Next scheduled run (relative; tooltip = absolute local time). -->
                                                        <Border Classes="badge live" IsVisible="{Binding HasNextRun}"
                                                                ToolTip.Tip="{Binding NextRunTooltip}">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <mi:MaterialIcon Kind="ClockOutline" Width="12" Height="12"
                                                                                 Foreground="{StaticResource TealBrush}" VerticalAlignment="Center" />
                                                                <TextBlock Text="{Binding NextRunText}" />
                                                            </StackPanel>
                                                        </Border>
                                                        <!-- Trigger failed to start: this task won't run automatically. -->
                                                        <Border Classes="badge warn" IsVisible="{Binding HasTriggerError}"
                                                                ToolTip.Tip="{Binding TriggerError}">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <mi:MaterialIcon Kind="AlertOutline" Width="12" Height="12"
                                                                                 Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center" />
                                                                <TextBlock Text="Trigger error" />
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Path}" Classes="path" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                    <mi:MaterialIcon Width="15" Height="15" VerticalAlignment="Center"
                                                                     Kind="{Binding HealthOutcome, Converter={x:Static conv:SyncOutcomeToIconKindConverter.Instance}}"
                                                                     Foreground="{Binding HealthOutcome, Converter={x:Static conv:SyncOutcomeToBrushConverter.Instance}}" />
                                                    <TextBlock Text="{Binding HealthText}" VerticalAlignment="Center"
                                                               Foreground="{Binding HealthOutcome, Converter={x:Static conv:SyncOutcomeToBrushConverter.Instance}}" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <Button Classes="icon run" Command="{Binding ExecuteCommand}" IsVisible="{Binding !IsRunning}" ToolTip.Tip="Run now"><mi:MaterialIcon Kind="Play" Width="16" Height="16" /></Button>
                                                    <Button Classes="icon danger" Command="{Binding CancelCommand}" IsVisible="{Binding IsRunning}" ToolTip.Tip="Stop"><mi:MaterialIcon Kind="Stop" Width="16" Height="16" /></Button>
                                                    <Button Classes="icon" Command="{Binding AddDestinationCommand}" ToolTip.Tip="Add destination"><mi:MaterialIcon Kind="Plus" Width="16" Height="16" /></Button>
                                                    <Button Classes="icon" Command="{Binding EditCommand}" ToolTip.Tip="Edit task"><mi:MaterialIcon Kind="Pencil" Width="15" Height="15" /></Button>
                                                    <Button Classes="icon" Command="{Binding DeleteCommand}" ToolTip.Tip="Delete task"><mi:MaterialIcon Kind="TrashCanOutline" Width="15" Height="15" /></Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Destinations -->
                                        <ItemsControl ItemsSource="{Binding Children}" IsVisible="{Binding IsExpanded}" Margin="0,0,0,4">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:DestinationNodeViewModel">
                                                    <Border BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,1,0,0" Padding="16,10,12,10">
                                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                                            <mi:MaterialIcon Grid.Column="0" Width="17" Height="17" VerticalAlignment="Center" Margin="0,0,11,0"
                                                                             Kind="{Binding Outcome, Converter={x:Static conv:SyncOutcomeToIconKindConverter.Instance}}"
                                                                             Foreground="{Binding Outcome, Converter={x:Static conv:SyncOutcomeToBrushConverter.Instance}}" />
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                                    <Border Classes="badge">
                                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                                            <mi:MaterialIcon Kind="{Binding StrategyIconKind}" Width="12" Height="12"
                                                                                             Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                                                            <TextBlock Text="{Binding StrategyText}" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <Border Classes="badge">
                                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                                            <mi:MaterialIcon Kind="FilterOutline" Width="12" Height="12"
                                                                                             Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                                                            <TextBlock Text="{Binding FilterText}" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Path}" Classes="path" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DisplayStatus}" VerticalAlignment="Center"
                                                                           MaxWidth="280" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding DisplayStatus}"
                                                                           Foreground="{Binding Outcome, Converter={x:Static conv:SyncOutcomeToBrushConverter.Instance}}" />
                                                                <Button Classes="icon" Command="{Binding ConfirmCommand}" IsVisible="{Binding NeedsConfirmation}" ToolTip.Tip="Review deletions">
                                                                    <mi:MaterialIcon Kind="AlertOutline" Width="15" Height="15" Foreground="{StaticResource WarningBrush}" />
                                                                </Button>
                                                                <Button Classes="icon" Command="{Binding EditCommand}" ToolTip.Tip="Edit destination"><mi:MaterialIcon Kind="Pencil" Width="14" Height="14" /></Button>
                                                                <Button Classes="icon" Command="{Binding DeleteCommand}" ToolTip.Tip="Delete destination"><mi:MaterialIcon Kind="TrashCanOutline" Width="14" Height="14" /></Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
            </Border>
        </Grid>

        <!-- In-window modal overlay; spans the title bar too (standard modal dimming). -->
        <Border Grid.Row="0" Grid.RowSpan="2" Classes="backdrop" IsVisible="{Binding DialogHost.IsOpen}">
            <ContentControl Content="{Binding DialogHost.CurrentDialog}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
