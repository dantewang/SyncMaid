<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SyncMaid.ViewModels"
        xmlns:conv="using:SyncMaid.Converters"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="620"
        x:Class="SyncMaid.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="True"
        Width="940" Height="620"
        Icon="/Assets/avalonia-logo.ico"
        TransparencyLevelHint="AcrylicBlur,Blur,None"
        Background="Transparent"
        Title="SyncMaid">

    <Grid>
        <!-- Frosted acrylic background; cards stay opaque so content readability is unaffected.
             Falls back to a solid fill when Windows transparency is disabled. -->
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="#F7F7F4"
                                             TintOpacity="1" MaterialOpacity="0.6" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <Grid ColumnDefinitions="Auto,Auto,*">
            <!-- Sidebar: compact task list -->
            <Border Grid.Column="0" Width="210" IsVisible="{Binding IsSidebarVisible}"
                    Background="Transparent" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,1,0">
                <DockPanel Margin="8">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="6,6,2,8">
                        <TextBlock Grid.Column="0" Text="Tasks" Classes="muted" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Classes="icon" Width="26" Height="26" Command="{Binding ToggleSidebarCommand}" ToolTip.Tip="Hide sidebar">
                            <mi:MaterialIcon Kind="ChevronLeft" Width="16" Height="16" />
                        </Button>
                    </Grid>
                    <ListBox Classes="sidebar" ItemsSource="{Binding Nodes}" SelectedItem="{Binding SelectedTask}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TaskNodeViewModel">
                                <Grid ColumnDefinitions="Auto,*" ToolTip.Tip="{Binding SidebarTooltip}">
                                    <mi:MaterialIcon Grid.Column="0" Kind="FolderOutline" Width="18" Height="18"
                                                     Foreground="{StaticResource TealBrush}" VerticalAlignment="Center" Margin="0,0,9,0" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TealBrush}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Path}" Classes="path" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Rail when sidebar hidden -->
            <Border Grid.Column="1" Width="40" IsVisible="{Binding !IsSidebarVisible}"
                    Background="Transparent" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,1,0">
                <Button Classes="icon" Width="26" Height="26" Command="{Binding ToggleSidebarCommand}"
                        HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0" ToolTip.Tip="Show sidebar">
                    <mi:MaterialIcon Kind="ChevronRight" Width="16" Height="16" />
                </Button>
            </Border>

            <!-- Main area: solid pane; the acrylic shows through the sidebar instead -->
            <Border Grid.Column="2" Background="{StaticResource PageBrush}">
            <DockPanel Margin="16,12">
                <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="0,0,0,12">
                    <TextBlock Grid.Column="0" Text="Sync tasks" Classes="h1" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="secondary" Command="{Binding ToggleExpandAllCommand}" Content="{Binding ExpandCollapseLabel}" Margin="0,0,8,0" />
                    <Button Grid.Column="3" Classes="secondary" Command="{Binding RunAllCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="Play" Width="15" Height="15" />
                            <TextBlock Text="Run all" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4" Classes="primary" Command="{Binding AddTaskCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="Plus" Width="15" Height="15" />
                            <TextBlock Text="New task" />
                        </StackPanel>
                    </Button>
                </Grid>

                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Nodes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TaskNodeViewModel">
                                <Border Classes="card">
                                    <StackPanel>
                                        <!-- Header -->
                                        <Grid ColumnDefinitions="*,Auto" Margin="10">
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <ToggleButton Classes="chevron" IsChecked="{Binding IsExpanded}" VerticalAlignment="Center" Margin="0,0,4,0">
                                                    <mi:MaterialIcon Width="18" Height="18"
                                                                     Kind="{Binding IsExpanded, Converter={x:Static conv:BoolToChevronKindConverter.Instance}}" />
                                                </ToggleButton>
                                                <Border Classes="chip" Margin="0,0,11,0">
                                                    <mi:MaterialIcon Kind="FolderOutline" Width="19" Height="19" Foreground="{StaticResource TealBrush}"
                                                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Name}" Classes="name" VerticalAlignment="Center" />
                                                        <Border Classes="badge">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <mi:MaterialIcon Kind="{Binding TriggerIconKind}" Width="12" Height="12"
                                                                                 Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                                                <TextBlock Text="{Binding TriggerText}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Path}" Classes="path" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                    <mi:MaterialIcon Width="15" Height="15" VerticalAlignment="Center"
                                                                     Kind="{Binding HealthOutcome, Converter={x:Static conv:SyncOutcomeToIconKindConverter.Instance}}"
                                                                     Foreground="{Binding HealthOutcome, Converter={x:Static conv:SyncOutcomeToBrushConverter.Instance}}" />
                                                    <TextBlock Text="{Binding HealthText}" VerticalAlignment="Center"
                                                               Foreground="{Binding HealthOutcome, Converter={x:Static conv:SyncOutcomeToBrushConverter.Instance}}" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <Button Classes="icon run" Command="{Binding ExecuteCommand}" ToolTip.Tip="Run now"><mi:MaterialIcon Kind="Play" Width="16" Height="16" /></Button>
                                                    <Button Classes="icon" Command="{Binding AddDestinationCommand}" ToolTip.Tip="Add destination"><mi:MaterialIcon Kind="Plus" Width="16" Height="16" /></Button>
                                                    <Button Classes="icon" Command="{Binding EditCommand}" ToolTip.Tip="Edit task"><mi:MaterialIcon Kind="Pencil" Width="15" Height="15" /></Button>
                                                    <Button Classes="icon" Command="{Binding DeleteCommand}" ToolTip.Tip="Delete task"><mi:MaterialIcon Kind="TrashCanOutline" Width="15" Height="15" /></Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Destinations -->
                                        <ItemsControl ItemsSource="{Binding Children}" IsVisible="{Binding IsExpanded}" Margin="0,0,0,4">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:DestinationNodeViewModel">
                                                    <Border BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,1,0,0" Padding="16,10,12,10">
                                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                                            <mi:MaterialIcon Grid.Column="0" Width="17" Height="17" VerticalAlignment="Center" Margin="0,0,11,0"
                                                                             Kind="{Binding Outcome, Converter={x:Static conv:SyncOutcomeToIconKindConverter.Instance}}"
                                                                             Foreground="{Binding Outcome, Converter={x:Static conv:SyncOutcomeToBrushConverter.Instance}}" />
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                                    <Border Classes="badge">
                                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                                            <mi:MaterialIcon Kind="{Binding StrategyIconKind}" Width="12" Height="12"
                                                                                             Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                                                            <TextBlock Text="{Binding StrategyText}" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <Border Classes="badge">
                                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                                            <mi:MaterialIcon Kind="FilterOutline" Width="12" Height="12"
                                                                                             Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                                                            <TextBlock Text="{Binding FilterText}" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Path}" Classes="path" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                                                                           Foreground="{Binding Outcome, Converter={x:Static conv:SyncOutcomeToBrushConverter.Instance}}" />
                                                                <Button Classes="icon" Command="{Binding EditCommand}" ToolTip.Tip="Edit destination"><mi:MaterialIcon Kind="Pencil" Width="14" Height="14" /></Button>
                                                                <Button Classes="icon" Command="{Binding DeleteCommand}" ToolTip.Tip="Delete destination"><mi:MaterialIcon Kind="TrashCanOutline" Width="14" Height="14" /></Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
            </Border>
        </Grid>

        <!-- In-window modal overlay -->
        <Border Classes="backdrop" IsVisible="{Binding DialogHost.IsOpen}">
            <ContentControl Content="{Binding DialogHost.CurrentDialog}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
