<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:vm="using:SyncMaid.ViewModels"
             xmlns:views="using:SyncMaid.Views"
             x:Class="SyncMaid.App"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <!-- Maps each editor view model to its view for the in-window modal host. -->
        <DataTemplate DataType="vm:TaskEditorViewModel"><views:TaskEditorView /></DataTemplate>
        <DataTemplate DataType="vm:DestinationEditorViewModel"><views:DestinationEditorView /></DataTemplate>
        <DataTemplate DataType="vm:SettingsViewModel"><views:SettingsView /></DataTemplate>
        <DataTemplate DataType="vm:ConfirmViewModel"><views:ConfirmView /></DataTemplate>
    </Application.DataTemplates>

    <!-- System tray icon. Declared here (rather than built in code) since TrayIcon is a
         control; its commands bind to the AppTrayViewModel that App sets as Application's
         DataContext at startup. Left-click / "Show main window" restores the window; "Exit"
         quits. The hide-vs-exit-on-close decision is event/lifetime logic and stays in code
         (TrayController), as does setting the DataContext (the controller needs the runtime
         window). -->
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/syncmaid.ico" ToolTipText="SyncMaid"
                      x:DataType="vm:AppTrayViewModel"
                      Command="{Binding ShowMainWindowCommand}">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Show main window" Command="{Binding ShowMainWindowCommand}" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="Exit" Command="{Binding ExitCommand}" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>

    <Application.Resources>
        <!-- Flat palette matching the design -->
        <SolidColorBrush x:Key="PageBrush" Color="#F7F7F4" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#F1F1ED" />
        <SolidColorBrush x:Key="HairlineBrush" Color="#E6E6E0" />
        <SolidColorBrush x:Key="HairlineStrongBrush" Color="#D6D6CF" />

        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1B1B18" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6C6C66" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9A9A92" />

        <!-- Brand accent: cyan drawn from the app icon's hair-bow accessory (#36D6E2),
             deepened for legible white-on-fill and text-on-light contrast. Keys kept as
             "Teal*" to avoid churn across the XAML that references them. -->
        <SolidColorBrush x:Key="TealBrush" Color="#1AA0B5" />
        <SolidColorBrush x:Key="TealHoverBrush" Color="#158799" />
        <SolidColorBrush x:Key="TealPressedBrush" Color="#106E7D" />
        <SolidColorBrush x:Key="TealSubtleBrush" Color="#E3F5F8" />

        <SolidColorBrush x:Key="DangerBrush" Color="#C53943" />
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#B00613" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#1AA0B5" />
        <SolidColorBrush x:Key="WarningBrush" Color="#C7810B" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <materialIcons:MaterialIconStyles />
        <StyleInclude Source="avares://SyncMaid/Styles/Theme.axaml" />
    </Application.Styles>
</Application>
