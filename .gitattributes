# Normalize all text files to LF in the repository.
* text=auto eol=lf

# Explicit text types
*.cs       text eol=lf
*.axaml    text eol=lf
*.xaml     text eol=lf
*.csproj   text eol=lf
*.sln      text eol=lf
*.manifest text eol=lf
*.json     text eol=lf
*.xml      text eol=lf
*.md       text eol=lf
*.txt      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf

# Binary files — never normalize
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.dll  binary
*.exe  binary
*.pdf  binary
